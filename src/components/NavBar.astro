<script>
  import { gsap } from 'gsap'
  document.addEventListener("DOMContentLoaded",e=>{
    const menu_hamburger = document.getElementById('menu-hamburger')
    const menu_mobil = document.getElementById('menu-mobil')
    if(!menu_hamburger) return
    let on_progress = false
    let tl = gsap.timeline({paused:true})
    tl
    .to('.line-menu',{
      y:function(index,target){
        return menu_hamburger.clientHeight/2 - target.offsetTop - target.clientHeight/2
      },
      background:'#000000',
      duration:.25,
    })
    .to('.line-menu:nth-child(2)',{
      opacity:0,
      duration:0
    })
    .to(['.line-menu:first-child'],{
      rotateZ:30,
      duration:.5,
      ease:'elastic.out'
    })
    .to(['.line-menu:last-child'],{
      rotateZ:-30,
      duration:.5,
      ease:'elastic.out',
      onComplete:()=>{
        on_progress = false
      }
    },'<')
    let tl2 = gsap.timeline({paused:true})
    tl2
    .to(['.line-menu:first-child','.line-menu:last-child'],{
      rotateZ:0,
      duration:.2,
    })
    .to('.line-menu:nth-child(2)',{
      opacity:1,
      duration:0
    })
    .to('.line-menu',{
      y:0,
      duration:.2,
      background:'#b6b6b6',
      onComplete:()=>{
        on_progress = false
      }
    })

    gsap.set('.nav_option',{opacity:0,scale:.8})
    let tween1 = gsap.to('.nav_option',{
      paused:true,
      opacity:1,
      scale:1,
      stagger:{
        each: 0.1,
        from: 'center',
        grid: 'auto',
        ease: 'power2.inOut',
      }
    })
    const closeNav = (open:number)=>{
      if(!menu_mobil) return 0
      gsap.to(menu_mobil,{
        x: open ?  0 : menu_mobil.clientWidth,
        duration:.25,
        onComplete:()=>{
          menu_hamburger.dataset.open = open ? '0' : '1'
          tween1.play()
        },
      })
      if(open){
        tl2.restart().play()          
      }else{
        tl.restart().play()
        tween1.restart()
      }
    }
    
    menu_hamburger?.addEventListener('click',e=>{
      if(e.target instanceof HTMLElement && !on_progress){
        on_progress = true
        const open = parseInt(e.target.dataset.open ?? '0')
        closeNav(open)
      }
    })
    let nav_options = document.querySelectorAll('.nav_option')
    for(let nav_option of nav_options){
      if(!(nav_option instanceof HTMLElement)) return
      nav_option.addEventListener('click',e=>{
        const open = parseInt(menu_hamburger.dataset.open ?? '0')
        closeNav(open)
      })
    }
  })
</script>
