<script>
  const slider = document.getElementById('pp')
  const controls = document.querySelectorAll('#controls>div')
  const buttons_slider = document.querySelectorAll('.button_slider')
  let intervalId = 0, init = 1
  let updateControlActive = (position:number)=>{
    controls.forEach(item=>item.classList.remove('active'))
    controls[position].classList.add('active')
  }
  let initInterval = ()=>{
    clearInterval(intervalId)
    intervalId = setInterval(()=>{
      init = (init%3) + 1
      let slide = slider!.querySelector(`div:nth-child(${init})`)
      if(!(slide instanceof HTMLElement)) return
      slider?.scrollTo({
        left:slide.offsetLeft,
        behavior:'smooth'
      })
      updateControlActive(init-1)
    },5000)
  }
  document.addEventListener('DOMContentLoaded',e=>{
    if(!controls) return 0
    controls.forEach((control,indice)=>{
      if(!(control instanceof HTMLElement)) return
      control.addEventListener('click',e=>{
        let slide = slider!.querySelector(`div:nth-child(${indice+1})`)
        init = ((indice + 1)%3)

        if(!(slide instanceof HTMLElement)) return
        slider?.scrollTo({
          left:slide.offsetLeft,
          behavior:'smooth'
        })
        updateControlActive(indice)
        initInterval()
      })
    })
    buttons_slider.forEach((button,index)=>{
      button.addEventListener('click',e=>{
        if(!(button instanceof HTMLElement)) return
        let direction = button.dataset.direction
        init = init + (direction == 'right' ? 1 : -1)
        if(init > 3) init = 1
        if(init < 1) init = 3
        let slide = slider!.querySelector(`div:nth-child(${init})`)

        if(!(slide instanceof HTMLElement)) return
        slider?.scrollTo({
          left:slide.offsetLeft,
          behavior:'smooth'
        })
        updateControlActive(init-1)
        initInterval()
      })
    })
    initInterval()
  })
</script>
<section id="slider" class="w-full h-auto relative">
  <div id="pp" class="w-full h-auto border-0 flex overflow-hidden snap-x snap-mandatory [&>div]:w-full [&>div]:shrink-0 [&>div]:snap-center">
    <div class="bg-red-400">
      <!-- <img src="/banner_menu.png" alt="banner_1" class="w-full h-auto" /> -->
      <img src="/banner_menu.png" alt="banner_1" class="w-full hidden md:block" />
      <img src="/banner_2.png" alt="banner_2" class="w-full md:hidden" />
    </div>
    <div class="bg-green-400">s</div>
    <div class="bg-blue-400">s</div>
  </div>
  <div class="absolute w-full px-4 lg:px-10 flex items-center justify-between [&>div]:w-12 [&>div]:h-12 lg:[&>div]:w-15 lg:[&>div]:h-15 [&>div]:rounded-full [&>div]:bg-lucha-gray-sticker/60 [&>div:hover]:bg-lucha-gray-sticker/80 [&>div]:backdrop-blur-sm top-0 bottom-0 my-auto [&>div]:cursor-pointer [&>div]:p-2">
    <div class="button_slider" data-direction="left"><img src="/arrow_back.svg" alt="back" class="w-full"/></div>
    <div class="button_slider" data-direction="right"><img src="/arrow_forward.svg" alt="back" class="w-full"/></div>
  </div>
  <div class="absolute w-full h-auto border-0 bottom-0 flex justify-center items-center">
    <div id="controls" class="[&>div]:h-3 [&>div.active]:w-10 [&>div]:w-3 [&>div]:transition-all [&>div]:rounded-full [&>div]:bg-lucha-gray-sticker/60 [&>div]:backdrop-blur-sm [&>div]:cursor-pointer flex gap-1 py-4">
      <div class="active"></div>
      <div class=""></div>
      <div class=""></div>
    </div>
  </div>
</section>