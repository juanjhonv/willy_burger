<script>
  const slider = document.getElementById('pp')
  const controls = document.querySelectorAll('#controls>div')
  let intervalId = 0, init = 2
  let interval = ()=>{
    let slide = slider!.querySelector(`div:nth-child(${init})`)
    if(!(slide instanceof HTMLElement)) return
    slider?.scrollTo({
      left:slide.offsetLeft,
      behavior:'smooth'
    })
    init = (init%3) + 1
    // if(init + 1 > 3){
    //   init = 1
    // } else {
    //   init += 1
    // }
  }
  document.addEventListener('DOMContentLoaded',e=>{
    if(!controls) return 0
    controls.forEach((control,indice)=>{
      if(!(control instanceof HTMLElement)) return
      control.addEventListener('click',e=>{
        let slide = slider!.querySelector(`div:nth-child(${indice+1})`)
        init = ((indice + 1)%3) + 1

        if(!(slide instanceof HTMLElement)) return
        slider?.scrollTo({
          left:slide.offsetLeft,
          behavior:'smooth'
        })
        clearInterval(intervalId)
        intervalId = setInterval(interval,5000)
      })
    })
    intervalId = setInterval(interval,5000)
  })
</script>
<section id="slider" class="w-full h-auto relative">
  <div id="pp" class="w-full h-auto border-0 flex overflow-hidden snap-x snap-mandatory [&>div]:w-full [&>div]:shrink-0 [&>div]:snap-center">
    <div class="bg-red-400">
      <!-- <img src="/banner_menu.png" alt="banner_1" class="w-full h-auto" /> -->
      <img src="/banner_menu.png" alt="banner_1" class="w-full hidden md:block" />
      <img src="/banner_2.png" alt="banner_2" class="w-full md:hidden" />
    </div>
    <div class="bg-green-400">s</div>
    <div class="bg-blue-400">s</div>
  </div>
  <div class="absolute w-full h-auto border-0 bottom-0 flex justify-center items-center">
    <div id="controls" class="[&>div]:w-3 [&>div]:h-3 [&>div]:rounded-full [&>div]:bg-gray-500 [&>div]:cursor-pointer flex gap-4 py-4">
      <div></div>
      <div></div>
      <div></div>
    </div>
  </div>
</section>